+// Thread-local storage for vector<bool> to TArrayRef<const bool> conversion
+// This is a workaround for GCC where std::vector<bool> is bit-packed
+// We use vector<char> which is NOT bit-packed and reinterpret_cast to bool*
+namespace NPrivate {
+    inline thread_local std::vector<char> gBoolStorage;
+
+    inline const bool* GetBoolStorageData(const std::vector<bool>& src) {
+        gBoolStorage.clear();
+        gBoolStorage.reserve(src.size());
+        for (size_t i = 0; i < src.size(); ++i) {
+            gBoolStorage.push_back(src[i] ? 1 : 0);
+        }
+        return reinterpret_cast<const bool*>(gBoolStorage.data());
+    }
+}
+
+// Specialization of TArrayRef for const bool to handle vector<bool>
+template <>
+class TArrayRef<const bool> {
+public:
+    using iterator = const bool*;
+    using const_iterator = const bool*;
+    using reference = const bool&;
+    using const_reference = const bool&;
+    using value_type = bool;
+    using reverse_iterator = std::reverse_iterator<iterator>;
+
+private:
+    const bool* Data_ = nullptr;
+    size_t Len_ = 0;
+
+public:
+    constexpr TArrayRef() noexcept = default;
+
+    constexpr TArrayRef(const bool* data, size_t len) noexcept
+        : Data_(data)
+        , Len_(len)
+    {
+    }
+
+    template <class Alloc>
+    TArrayRef(const std::vector<bool, Alloc>& v)
+        : Data_(v.empty() ? nullptr : NPrivate::GetBoolStorageData(v))
+        , Len_(v.size())
+    {
+    }
+
+    constexpr TArrayRef(const TArrayRef&) noexcept = default;
+
+    constexpr const_iterator begin() const noexcept { return Data_; }
+    constexpr const_iterator end() const noexcept { return Data_ + Len_; }
+    constexpr const bool* data() const noexcept { return Data_; }
+    constexpr size_t size() const noexcept { return Len_; }
+    Y_PURE_FUNCTION constexpr bool empty() const noexcept { return !Len_; }
+    constexpr const_reference operator[](size_t n) const noexcept { return Data_[n]; }
+};
+
 template <class T>
 using TConstArrayRef = TArrayRef<const T>;

