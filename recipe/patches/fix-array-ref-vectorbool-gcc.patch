+// Thread-local storage for vector<bool> to TArrayRef<const bool> conversion
+// This is a workaround for GCC where std::vector<bool> is bit-packed
+namespace NPrivate {
+    inline thread_local std::vector<char> gBoolStorage;
+
+    inline const bool* GetBoolStorageData(const std::vector<bool>& src) {
+        gBoolStorage.clear();
+        gBoolStorage.reserve(src.size());
+        for (size_t i = 0; i < src.size(); ++i) {
+            gBoolStorage.push_back(src[i] ? 1 : 0);
+        }
+        return reinterpret_cast<const bool*>(gBoolStorage.data());
+    }
+}
+
+// Specialization of TArrayRef for const bool to handle vector<bool>
+template <>
+class TArrayRef<const bool> {
+public:
+    using iterator = const bool*;
+    using const_iterator = const bool*;
+    using value_type = bool;
+
+private:
+    const bool* T_ = nullptr;
+    size_t S_ = 0;
+
+public:
+    constexpr TArrayRef() noexcept = default;
+    constexpr TArrayRef(const bool* data, size_t len) noexcept : T_(data), S_(len) {}
+    template <class Alloc>
+    TArrayRef(const std::vector<bool, Alloc>& v) : T_(v.empty() ? nullptr : NPrivate::GetBoolStorageData(v)), S_(v.size()) {}
+    // Constructor accepting vector<unsigned char> (TVector<ui8>) - directly reinterprets as bool*
+    template <class Alloc>
+    constexpr TArrayRef(const std::vector<unsigned char, Alloc>& v) noexcept
+        : T_(v.empty() ? nullptr : reinterpret_cast<const bool*>(v.data())), S_(v.size()) {}
+    constexpr TArrayRef(const TArrayRef&) noexcept = default;
+    constexpr const_iterator begin() const noexcept { return T_; }
+    constexpr const_iterator end() const noexcept { return T_ + S_; }
+    constexpr const bool* data() const noexcept { return T_; }
+    constexpr size_t size() const noexcept { return S_; }
+    Y_PURE_FUNCTION constexpr bool empty() const noexcept { return !S_; }
+    constexpr const bool& operator[](size_t n) const noexcept { return T_[n]; }
+    constexpr explicit operator bool() const noexcept { return S_ > 0; }
+};
