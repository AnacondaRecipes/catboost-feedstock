@@ -18,6 +18,13 @@ if (ANDROID)
   endif()
 elseif (CMAKE_SYSTEM_NAME MATCHES "^(Darwin|Linux)$")
   add_link_options("-nodefaultlibs")
+  # When using -nodefaultlibs, we need to explicitly link default libraries
+  # Order matters: higher-level libs first, then their dependencies
+  add_link_options(
+    $<$<LINK_LANGUAGE:CXX>:-lstdc++>
+    $<$<LINK_LANGUAGE:CXX>:-lm>
+    $<$<LINK_LANGUAGE:CXX>:-ldl>
+    $<$<LINK_LANGUAGE:CXX>:-lgcc_s>
+    $<$<LINK_LANGUAGE:CXX>:-lc>
+  )
 endif()

