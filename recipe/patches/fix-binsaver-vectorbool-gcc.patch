+        if (IsReading()) {
+            data.clear();
+            Add(2, &nSize);
+            data.resize(nSize);
+        } else {
+            nSize = data.size();
+            CheckOverflow(nSize, data.size());
+            Add(2, &nSize);
+        }
+        for (TStoredSize i = 0; i < nSize; i++) {
+            bool val = IsReading() ? false : static_cast<bool>(data[i]);
+            Add(1, &val);
+            if (IsReading()) data[i] = val;
+        }
+    }
