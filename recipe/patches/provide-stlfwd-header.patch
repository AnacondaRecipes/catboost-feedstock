--- /dev/null
+++ contrib/libs/cxxsupp/stlfwd_compat/stlfwd
@@ -0,0 +1,45 @@
+#pragma once
+
+// Minimal stlfwd header compatible with GCC/libstdc++
+// Forward declarations for standard library types
+
+#include <cstddef>
+
+namespace std {
+
+// Pair
+template <class T1, class T2> struct pair;
+
+// Array
+template <class T, size_t N> class array;
+
+// Sequence containers
+template <class T, class Allocator> class vector;
+template <class T, class Allocator> class list;
+template <class T, class Allocator> class deque;
+
+// Associative containers
+template <class Key, class Compare, class Allocator> class set;
+template <class Key, class Compare, class Allocator> class multiset;
+template <class Key, class T, class Compare, class Allocator> class map;
+template <class Key, class T, class Compare, class Allocator> class multimap;
+
+// Tuple
+template <class... Types> class tuple;
+
+// Smart pointers
+template <class T> struct default_delete;
+template <class T, class Deleter> class unique_ptr;
+template <class T> class shared_ptr;
+
+// Function
+template <class> class function;
+
+// String view
+template <class CharT, class Traits> class basic_string_view;
+
+}  // namespace std
+
+namespace std { namespace filesystem {
+class path;
+}}  // namespace std::filesystem
