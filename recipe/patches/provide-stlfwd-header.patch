diff --git a/contrib/libs/cxxsupp/stlfwd_compat/stlfwd b/contrib/libs/cxxsupp/stlfwd_compat/stlfwd
new file mode 100644
--- /dev/null
+++ b/contrib/libs/cxxsupp/stlfwd_compat/stlfwd
@@ -0,0 +1,19 @@
+#pragma once
+
+// GCC/libstdc++ compatible stlfwd header
+// Unlike libc++, libstdc++ doesn't have a dedicated forward declarations header.
+// We include the necessary standard headers to get the required type definitions.
+
+// Core type definitions needed by catboost's util/generic/fwd.h
+#include <cstddef>
+#include <memory>      // std::allocator - required for default template args
+#include <functional>  // std::function, std::hash
+#include <utility>     // std::pair
+#include <tuple>       // std::tuple
+#include <string>      // std::basic_string, std::char_traits
+#include <string_view> // std::basic_string_view
+
+// Filesystem (C++17)
+#if __cplusplus >= 201703L
+#include <filesystem>  // std::filesystem::path
+#endif
