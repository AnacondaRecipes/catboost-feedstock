Fix __host__/__device__ `pow` ambiguities in catboost CUDA kernels.

CUDA 12.x's nvcc (with newer libcudacxx) restricts which `pow` overloads are
callable from `__device__` code. Bare `pow(float, integer-expr)` and
`pow(float, float)` on a value reduced from integer arithmetic resolve to
the `__host__`-only overload set, producing:

    error: calling a __host__ function("pow(float, float)") from a
           __device__ function

Four files need disambiguation:

  - dcg.cu / NDCG decay loop: cast the integer subtraction result to T.
  - score_calcers.cuh / leaf-score accumulator: cast MetaExponent to double.
  - random_gen.cuh / NextGamma: switch to `powf` (explicit float overload
    that's __device__-callable on all CUDA versions we support).
  - transform.cu / PowVectorImpl: switch to `powf`. The kernel template
    is only instantiated for `float` (Y_MAP_ARGS(..., float)), so powf
    is type-correct.

--- a/catboost/cuda/targets/kernel/dcg.cu
+++ b/catboost/cuda/targets/kernel/dcg.cu
@@ -53,7 +53,7 @@
 {
     ui64 i = blockIdx.x * blockDim.x + threadIdx.x;
     while (i < size) {
-        decays[i] = pow(base, i - __ldg(offsets + i));
+        decays[i] = pow(base, static_cast<T>(i - __ldg(offsets + i)));
         i += gridDim.x * blockDim.x;
     }
 }
--- a/catboost/cuda/methods/kernel/score_calcers.cuh
+++ b/catboost/cuda/methods/kernel/score_calcers.cuh
@@ -52,7 +52,7 @@

         __forceinline__ __host__ __device__ void AddLeaf(double sum, double weight) {
             double leafScore = (weight > 1e-20f ? (-sum * sum) / (weight + Lambda) : 0);
-            Score += (MetaExponent == 1.0f || leafScore == 0.0f) ? leafScore : std::copysign(pow(std::abs(leafScore) / weight, MetaExponent), leafScore) * weight;
+            Score += (MetaExponent == 1.0f || leafScore == 0.0f) ? leafScore : std::copysign(pow(std::abs(leafScore) / weight, static_cast<double>(MetaExponent)), leafScore) * weight;
         }

         __forceinline__ __host__ __device__ double GetScore() {
--- a/catboost/cuda/cuda_util/kernel/random_gen.cuh
+++ b/catboost/cuda/cuda_util/kernel/random_gen.cuh
@@ -99,7 +99,7 @@
                 break;
             }
         }
-        return w > 0 ? (origScale * result * pow(w, 1.0f / (shape - 1.0f))) : result;
+        return w > 0 ? (origScale * result * powf(w, 1.0f / (shape - 1.0f))) : result;
     }

     __forceinline__ __device__
--- a/catboost/cuda/cuda_util/kernel/transform.cu
+++ b/catboost/cuda/cuda_util/kernel/transform.cu
@@ -355,7 +355,7 @@
     __global__ void PowVectorImpl(T* const x, const T base, const ui64 size) {
         ui64 i = (ui64)blockIdx.x * blockDim.x + threadIdx.x;
         while (i < size) {
-            x[i] = pow(base, x[i]);
+            x[i] = powf(base, x[i]);
             i += (ui64)gridDim.x * blockDim.x;
         }
     }
@@ -384,7 +384,7 @@
     __global__ void PowVectorImpl(const T* const x, const T base, const ui64 size, T* y) {
         ui64 i = (ui64)blockIdx.x * blockDim.x + threadIdx.x;
         while (i < size) {
-            y[i] = pow(base, x[i]);
+            y[i] = powf(base, x[i]);
             i += (ui64)gridDim.x * blockDim.x;
         }
     }
