Let conda's build env drive the clang toolchain (don't hardcode upstream).

Upstream catboost's clang.toolchain ships several settings that fight with
conda's compiler-wrapper layout:

  set(CMAKE_C_COMPILER clang)             # bare 'clang' isn't on PATH;
  set(CMAKE_CXX_COMPILER clang++)         #   we have ${HOST}-clang/-clang++
  set(CMAKE_CUDA_HOST_COMPILER clang-14)  # pins to a specific older clang
  set(ENV{CC} clang)                      # overrides our exported CC/CXX
  set(ENV{CXX} clang++)
  set(ENV{NVCC_PREPEND_FLAGS} ...)        # overrides our exported -ccbin

We export CC/CXX (pointing at the conda clang symlinks) and
NVCC_PREPEND_FLAGS (with -ccbin=${HOST}-clang++, --allow-unsupported-compiler,
-std=c++17) from build.sh. Stripping these toolchain lines lets those exports
actually take effect.

Note especially the NVCC_PREPEND_FLAGS line: catboost added it in 1.2.10.
Without removing it, nvcc receives only "--allow-unsupported-compiler
-std=c++17" (no -ccbin), so cmake's CUDA compiler-identification step
defaults to bare `g++` -- which isn't on PATH in the conda compiler-wrapper
layout -- and fails with `gcc: error trying to exec 'cc1plus'`.

--- a/build/toolchains/clang.toolchain
+++ b/build/toolchains/clang.toolchain
@@ -1,11 +1,8 @@
-set(CMAKE_C_COMPILER clang)
-set(CMAKE_CXX_COMPILER clang++)

 set(CMAKE_C_STANDARD_LIBRARIES "-lc -lm")
 set(CMAKE_CXX_STANDARD_LIBRARIES "-lc -lm")

 set(CMAKE_CUDA_COMPILER nvcc)
-set(CMAKE_CUDA_HOST_COMPILER clang-14)

 set(CMAKE_CUDA_FLAGS_INIT "--allow-unsupported-compiler")

@@ -14,10 +11,6 @@ if (NOT APPLE)
   set(CMAKE_SHARED_LINKER_FLAGS -fuse-ld=lld)
 endif()

-set(ENV{CC} clang)
-set(ENV{CXX} clang++)
-set(ENV{NVCC_PREPEND_FLAGS} "--allow-unsupported-compiler -std=c++17")
-
 set(CMAKE_FIND_ROOT_PATH_MODE_PROGRAM NEVER)
 set(CMAKE_FIND_ROOT_PATH_MODE_LIBRARY ONLY)
 set(CMAKE_FIND_ROOT_PATH_MODE_INCLUDE ONLY)
